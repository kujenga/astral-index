# Astral Index — environment variables
# Copy to .env and fill in what you need. All are optional.

# LLM (Claude) — classification, summaries, eval judges
# https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=

# Reddit scraping
# Create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Twitter/X scraping via SocialData.tools
# https://socialdata.tools/app/api-keys
SOCIALDATA_API_KEY=

# Newsletter publishing via Buttondown
# https://buttondown.com/keys
BUTTONDOWN_API_KEY=

# Eval tracing via Braintrust (optional)
# https://www.braintrust.dev/app/settings/api-keys
BRAINTRUST_API_KEY=
